{
    "name":  "pupy-backend",
    "version":  "1.0.0",
    "description":  "PUPY (鐖綇) - 瀹犵墿绀句氦骞冲彴鍚庣 | Pet Social Platform Backend",
    "type":  "module",
    "main":  "dist/index.js",
    "scripts":  {
                    "dev":  "tsx watch src/index.ts",
                    "build":  "tsc",
                    "start":  "node dist/index.js",
                    "preview":  "node dist/index.js",
                    "lint":  "tsc --noEmit",
                    "db:init":  "node dist/scripts/initDb.js",
                    "db:seed":  "node dist/scripts/seed.js",
                    "db:seed:rich":  "tsx src/scripts/seedRichDemo.ts",
                    "db:migrate:operations":  "tsx src/scripts/migrateOperationsToSupabase.ts"
                },
    "dependencies":  {
                         "express":  "^4.21.2",
                         "cors":  "^2.8.5",
                         "dotenv":  "^17.2.3",
                         "jsonwebtoken":  "^9.0.2",
                         "bcryptjs":  "^2.4.3",
                         "@supabase/supabase-js":  "^2.39.8",
                         "uuid":  "^9.0.1",
                         "validator":  "^13.11.0",
                         "axios":  "^1.6.5"
                     },
    "devDependencies":  {
                            "@types/node":  "^22.14.0",
                            "@types/cors":  "^2.8.17",
                            "@types/express":  "^4.17.21",
                            "@types/jsonwebtoken":  "^9.0.7",
                            "@types/bcryptjs":  "^2.4.6",
                            "@types/uuid":  "^9.0.7",
                            "@types/validator":  "^13.11.8",
                            "typescript":  "~5.8.2",
                            "tsx":  "^4.21.0"
                        }
}
